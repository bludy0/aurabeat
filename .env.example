# =========================================================
# AuraBeat - Çevre Değişkenleri (Environment Variables)
# Bu dosyayı doğrudan .env olarak kopyalayın ve değerleri girin
# ÖNEMLİ: Gerçek .env dosyanızı ASLA GitHub'a pushlamayın!
# =========================================================

# -----------------
# 1. SUNUCU AYARLARI
# -----------------
# Uygulamanın çalışacağı temel port (Node.js/Express)
PORT=5000
NODE_ENV=development

# -----------------
# 2. VERİTABANI
# -----------------
# MongoDB Bağlantı URL'si (Atlas veya Localhost)
# Örnek: mongodb+srv://<username>:<password>@cluster0.mongodb.net/aurabeat
MONGODB_URI=mongodb://localhost:27017/aurabeat_dev

# -----------------
# 3. KİMLİK DOĞRULAMA (AUTH)
# -----------------
# JWT Token oluşturmak için kullanılacak gizli anahtar (Karmaşık bir string olmalıdır)
JWT_SECRET=CHANGE_ME_use_a_strong_random_secret_here
# Token geçerlilik süresi (Örn: 1d, 7d, 24h)
JWT_EXPIRES_IN=7d

# -----------------
# 4. YZ (AI) API ANAHTARLARI
# -----------------
# Akor, Söz ve Müzik İskeleti üretimi (Text/JSON generation)
OPENAI_API_KEY=sk-proj-buraya_openai_anahtarinizi_yazin
# VEYA
GEMINI_API_KEY=AIzaSy_buraya_gemini_anahtarinizi_yazin

# Gerçek Ses Üretimi ve Sinyal İşleme (Suno/Udio/MusicGen)
SUNO_API_KEY=sun-buraya_suno_anahtar_veya_cookie_degeri
AUDIO_MODEL_PROVIDER=suno

# -----------------
# 5. FRONTEND & CORS
# -----------------
# API'ye istekte bulunmasına izin verilen kök adres (Örn: localhost veya Vercel URL'i)
CLIENT_URL=http://localhost:3000

# -----------------
# 6. CDN / DOSYA DEPOLAMA
# -----------------
# Üretilen ses dosyalarının saklanacağı servis (AWS S3, Cloudinary vb.)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# AWS_S3_BUCKET=aurabeat-audio
# AWS_S3_REGION=eu-central-1
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
